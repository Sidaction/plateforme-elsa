	<div id="partenaires">
    	<div class="titreSoul"><span>Les membres de la plateforme ELSA</span></div>
        <ul>
        					<li><a href="/plateforme-elsa/associations-membres-de-la-plateforme-elsa/"><img width="109" height="64" src="http://www.plateforme-elsa.org/wp-content/uploads/2014/02/Logo_aides.png" class="attachment-medium wp-post-image" alt="Logo Aides" /></a></li>
