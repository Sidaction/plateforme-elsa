        <article class="noback">
        <h1>3SH</h1>
        
        <!-- ZONE IMAGE -->
        <div id="infosStructure">
        	<div class="thumbStructure"><img width="150" height="58" src="http://www.plateforme-elsa.org/wp-content/uploads/2014/02/Logo_3SH.png" class="attachment-medium wp-post-image" alt="Logo_3SH" /></div>
            <strong><a href="/pays/cameroun"/>Cameroun</a> </strong><br /><br />
           
          
            <a href="http://www.3sh.org/" target="_blank"><img src="http://www.plateforme-elsa.org/wp-content/themes/elsa-responsive/_img/i_web.png" /></a>                         <a href="mailto:info@3sh.org"><img src="http://www.plateforme-elsa.org/wp-content/themes/elsa-responsive/_img/i_mail.png" /></a>              
        </div> 
 		<!-- ZONE IMAGE -->
        
        
       <!-- INFOS GENERALES -->
       
       	<div class="contentDetails">
        <span>Activité(s) :</span> sciences sociales <br />
        <span>Publics cibles :</span> tous publics <br />
        
                </div> 
        
           <div class="contentDetails2">
